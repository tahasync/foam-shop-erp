rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // User data access
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);

      // Products
      match /products/{productId} {
        allow write: if isOwner(userId)
          && request.resource.data.current_stock is number
          && request.resource.data.current_stock >= 0
          && request.resource.data.cost_price is number
          && request.resource.data.cost_price >= 0;
      }

      // Sales
      match /sales/{saleId} {
        allow write: if isOwner(userId)
          && request.resource.data.line_items is list
          && request.resource.data.line_items.size() > 0
          && request.resource.data.paid is number
          && request.resource.data.paid >= 0;
      }

      // Purchases
      match /purchases/{purchaseId} {
        allow write: if isOwner(userId)
          && request.resource.data.cost_amount is number
          && request.resource.data.cost_amount > 0;
      }
    }
  }
}
