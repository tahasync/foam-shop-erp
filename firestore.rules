rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isNonEmpty(val) {
      return val is string && val.size() > 0;
    }

    function isPositiveNumber(val) {
      return val is number && val >= 0;
    }

    // User data access — strict tenant isolation
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);

      // Products
      match /products/{productId} {
        allow write: if isOwner(userId)
          && isPositiveNumber(request.resource.data.current_stock)
          && isPositiveNumber(request.resource.data.cost_price);
        allow delete: if false;
      }

      // Sales
      match /sales/{saleId} {
        allow write: if isOwner(userId)
          && request.resource.data.line_items is list
          && request.resource.data.line_items.size() > 0
          && isPositiveNumber(request.resource.data.paid);
        allow delete: if false;
      }

      // Purchases
      match /purchases/{purchaseId} {
        allow write: if isOwner(userId)
          && isPositiveNumber(request.resource.data.cost_amount)
          && request.resource.data.cost_amount > 0;
        allow delete: if false;
      }

      // Payments — require positive amount
      match /payments/{paymentId} {
        allow write: if isOwner(userId)
          && isPositiveNumber(request.resource.data.amount_collected);
        allow delete: if false;
      }

      // Supplier payments
      match /supplier_payments/{spId} {
        allow write: if isOwner(userId)
          && isPositiveNumber(request.resource.data.amount_paid);
        allow delete: if false;
      }

      // Expenses
      match /expenses/{expenseId} {
        allow write: if isOwner(userId)
          && isPositiveNumber(request.resource.data.amount);
        allow delete: if false;
      }

      // Opening balance — only one doc allowed
      match /opening_balances/{obId} {
        allow write: if isOwner(userId)
          && isPositiveNumber(request.resource.data.capital_amount);
        allow delete: if false;
      }
    }
  }
}
